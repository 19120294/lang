# ============================================================
# Lặng Backend — Environment Variables
# Copy file này thành .env và điền giá trị thực
# KHÔNG commit file .env lên git
# ============================================================

# Database
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lang_db?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Encryption key cho health data (AES-256-GCM)
# Tạo bằng: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY="your-64-char-hex-encryption-key-here"

# App
PORT=3001
FRONTEND_URL="http://localhost:4200"
NODE_ENV="development"

# Email (SMTP) — tùy chọn. Để trống khi dev (link reset sẽ in ra log).
# Gợi ý free: Brevo (smtp-relay.brevo.com:587) hoặc Mailjet (in-v3.mailjet.com:587)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
MAIL_FROM="Lặng <no-reply@lang.app>"
